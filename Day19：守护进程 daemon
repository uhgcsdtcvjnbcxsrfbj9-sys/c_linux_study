#include <stdio.h>
#include <stdlib.h>// // exit()
#include <unistd.h>//fork(), setsid(), chdir(), umask(), close(), sleep()
#include <fcntl.h>//open()
#include <sys/stat.h>// umask()

void daemonize() {
    if (fork() != 0) exit(0);
    setsid();
    if (fork() != 0) exit(0);
    chdir("/");
    umask(0);

    close(0); close(1); close(2);
    open("/dev/null", O_RDWR);
    dup(0); dup(0);
}

int main() {
    daemonize();

    while (1) {
        sleep(1);
    }
    return 0;
}



这段代码的作用：把程序变成【后台精灵】
脱离终端（关掉终端程序不死）
后台默默运行
不产生任何输出
这就是 Linux 服务器、后台服务的原理！


核心函数：daemonize () —— 变身守护进程
