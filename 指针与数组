#include <stdio.h>//引入标准输入输出库，只有包含它才能用 printf 打印
int main() {   Int main() {
    int arr[5] = {1, 2, 3, 4, 5};//定义一个整型数组，数组名 arr，长度 5；系统在内存中开辟连续的 5 个 int 空间（int 占 4 字节，总共 20 字节）；数组元素在内存里紧挨着存放：1 2 3 4 5；最重要：数组名 arr 等价于 &arr [0]（首元素地址）。
    int *p = arr; // 数组名 = 首元素地址//int *p：定义一个整型指针变量；因为 arr = 首元素地址，所以这行等价于 int *p = &arr[0];；效果：指针 p 指向数组的第一个元素 arr [0]。

    // 遍历：指针方式
    for (int i = 0; i < 5; i++) {
        printf("arr[%d] = %d, *(p+%d) = %d\n",i, arr[i], i, *(p+i));//*(p+i)：指针偏移 + 解引用取值；原理：p+i 不是地址 + 1 个字节，而是偏移 i 个元素长度（int 偏移 4 字节）。
    }

    // 指针加减
    p++; // 指向 arr[1]//指针 + 1：向后移动 1 个元素的长度，不是 + 1 字节；原本 p 指向 arr [0]，执行后：p 指向 arr [1]；只有指向数组的指针，做加减运算才有意义。
    printf("p++ 后 *p = %d\n", *p);printf("p 后 *p = %d\n", *p)；

    return 0;   
}
//数组是连续内存，数组名 = 首地址；
//指针可以用来遍历、操作数组，比下标更底层；
//arr[i] ↔ *(arr+i) ↔ *(p+i) ↔ p[i] 完全等价
//指针加减是按元素长度偏移，不是按字节。
//%d 是 C 语言 printf 函数里的格式占位符，专门用来输出十进制整数（int 类型）
