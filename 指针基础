#include <stdio.h>    //引入输入输出头文件，让程序能使用 printf 打印内容

int main() {
    int a = 10;//分配4字节内存空间
    int *p = &a; // p 存 a 的地址，定义一个整型指针变量 p，int *：代表这是一个指向 int 类型变量的指针，&a：& 是取地址符，作用是「拿到变量 a 在内存中的地址编号」；

    printf("a = %d\n", a);
    printf("*p = %d\n", *p); // 解引用取值
    printf("&a = %p, p = %p\n", &a, p);//*p：* 是解引用符（核心！）因为 p 存的是 a 的地址，所以 *p 等价于 a，打印结果：10
//%p：专门用来打印内存地址；&a 是 a 的地址，p 里存的就是 a 的地址
    *p = 20; // 通过指针修改 a
    printf("修改后 a = %d\n", a);解引用找到 a 的内存地址，直接修改该地址里的值；等价于直接写 a = 20；

    return 0;
}
//&	取地址符	拿变量的内存地址	&a → a 的地址
//*	指针声明	定义一个指针变量	int *p
//*	解引用符	通过地址取值 / 改值	*p = 20
