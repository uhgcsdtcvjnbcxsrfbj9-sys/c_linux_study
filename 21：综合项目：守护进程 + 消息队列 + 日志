#include <stdio.h>//输入输出：fopen, fprintf, fclose
#include <stdlib.h>//exit, 标准库
#include <unistd.h> fork, setsid, sleep
#include <sys/msg.h>消息队列：msgget, msgsnd, msgrcv
#include <time.h>//时间：time, ctime（写日志用）
#include <string.h>// 字符串操作

struct msg {
    long type;
    char buf[64];
};

void log_write(const char *msg) {
    FILE *fp = fopen("/tmp/ipc.log", "a");
    time_t now = time(NULL);
    fprintf(fp, "%s %s\n", ctime(&now), msg);
    fclose(fp);
}

int main() {
    if (fork() != 0) return 0;
    setsid();

    key_t key = 0x1234;
    int msqid = msgget(key, IPC_CREAT | 0666);

    if (fork() == 0) {//第二次 fork 的唯一目的：让守护进程彻底 “绝对安全”，永远不会再绑定终端！
        while (1) {
            struct msg m = {1, "data from child"};//1 → 消息类型（收消息时可以指定只收类型 1）
            msgsnd(msqid, &m, sizeof(m.buf), 0);
            sleep(2);
        }
        return 0;
    }

    while (1) {
        struct msg m;
        msgrcv(msqid, &m, sizeof(m.buf), 1, 0);
        log_write(m.buf);
    }

    return 0;
}

第一次 fork：爹死，儿活（B）
第二次 fork：儿（B）再生一个（C）
B 负责收消息
C 负责发消息
两个同时后台永远运行

