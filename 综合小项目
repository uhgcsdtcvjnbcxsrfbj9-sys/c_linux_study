#include <stdio.h>//文件操作 fopen / fclose / fwrite / fread / printf 都需要这个头文件。
#include <stdlib.h>   
#include <string.h>  
#define MAX_STUDENT 3//定义一个常量 MAX_STUDENT = 3表示最多存 3 个学生方便统一修改数量//宏定义

typedef struct  {
    int id;
    char name[20];   
    float score;  
} Student; //把多个变量打包成一个新类型 Student结构体在内存中是连续存放的所以可以一次性 fwrite /fread 读写整个结构体

// 保存学生到文件
void save_students(Student *s, int count) {
    FILE *fp = fopen("students.dat", "wb");
    if (fp == NULL) return;
    fwrite(s, sizeof(Student), count, fp);//s：学生数组首地址sizeof(Student)：一个学生结构体的大小count：要写入多少个学生fp：文件指针
    fclose(fp);   文件关闭(fp);
    printf("已保存 %d 条学生信息到文件\n", count);
}
//Student *s：接收学生数组的指针
int count：要保存的学生数量
打开文件 students.dat
wb = 二进制写入模式
文件不存在 → 创建
文件存在 → 清空重写
// 从文件加载学生
int load_students(Student *s) {
    FILE *fp = fopen("students.dat", "rb");
    if (fp == NULL) return 0;
    int count = fread(s, sizeof(Student), MAX_STUDENT, fp);//从文件读取最多 MAX_STUDENT 个学生读取的数据放到数组 s 中返回值 count = 实际读到的数量
    fclose(fp);   文件关闭(fp);
    return count;
}

// 打印学生
void print_students(Student *s, int count) {
    printf("\n===== 学生列表 =====\n");
    for (int i = 0; i < count; i++) {
        printf("ID:%d, 姓名:%s, 分数:%.1f\n",
               s[i].id, s[i].name, s[i].score);
    }
}

int main () {
    // 1. 录入学生
    Student students[MAX_STUDENT] = {
        {1, "Zhang", 85.5},
        {2, "Li", 92.0},
        {3, "Wang", 78.5}
    };

    // 2. 保存到文件
    save_students(students, MAX_STUDENT);//调用函数，把 3 个学生写入文件。

    // 3. 从文件加载
    Student load_buf[MAX_STUDENT];//定义数组，用于读取
    int load_count = load_students(load_buf);//读取文件内容到 load_buf 数组

    // 4. 打印
    print_students(load_buf, load_count);

    return 0;   
}
