#include <stdio.h>
#include <stdlib.h>

void func() {
    int stack_var = 10; // 栈变量：函数结束自动释放
    int *heap_var = (int *)malloc(sizeof(int));
    *heap_var = 20;     // 堆变量：必须手动 free

    printf("stack_var = %d (栈)\n", stack_var);
    printf("*heap_var = %d (堆)\n", *heap_var);

    // free(heap_var); // 故意注释，模拟内存泄漏
}

int main() {   Int main() {
    func();
    // 函数结束后，stack_var 已释放
    // heap_var 指向的内存仍占用（泄漏）
    return 0;   返回0;
}
