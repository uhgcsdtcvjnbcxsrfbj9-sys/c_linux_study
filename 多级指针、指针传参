#include <stdio.h>

int main() {   Int main() {
    int a = 100;
    int *p1 = &a;   // 一级指针//定义一级指针 p1，把 a 的地址存进去。
    int **p2 = &p1; // 二级指针：指向指针的指针  // 定义二级指针 p2，存 p1 的地址。int **：指向 “一级指针” 的指针，&p1：取 p1 自己的地址
    int ***p3 = &p2;// 三级指针（了解即可）

    printf("a = %d\n", a);   printf("a = %d\n", a);  //a = " 及变量 a 的值，然后换行
    printf("*p1 = %d\n", *p1);//\n：换行
    printf("**p2 = %d\n", **p2);//第一次 *p2：找到 p1，得到 a 的地址，第二次 * ：再找到 a，得到值
    printf("***p3 = %d\n", ***p3);

    **p2 = 200; // 通过二级指针修改 a//p2 存的是 p1 的地址，*p2 → 拿到 p1 里的值（a 的地址），，**p2 → 找到 a 本身，**p2 = 200 → 直接把 a 的值改成 200
    printf("修改后 a = %d\n", a);printf("After modification, a = %d\n", a);

    return 0;   
}
//a = 100
//*p1 = 100
//**p2 = 100
//***p3 = 100
//修改后 a = 200
