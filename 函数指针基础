#include <stdio.h>  

// 普通函数
int add(int a, int b) {
    return a + b;
}

int sub(int a, int b) {
    return a - b;
}//函数名本质上就是函数在内存中的地址

int main() {
    // 定义函数指针：返回int，参数(int,int)
    int (*calc)(int, int);//int：表示这个函数指针指向的函数返回 int，(*calc)：calc 是一个指针变量名，(int, int)：表示这个指针指向的函数有两个 int 参数，合起来意思：calc 是一个指针，它能指向 “返回 int、参数两个 int” 的函数

    calc = add; // 指向 add 函数//函数名 = 函数的地址所以这一句就是：让 calc 指针指向 add 函数
    printf("3 + 5 = %d\n", calc(3, 5));

    calc = sub; // 指向 sub 函数
    printf("10 - 3 = %d\n", calc(10, 3));

    return 0;   
}
//函数也存在内存里
函数代码是一段二进制指令
存在代码段
有自己的地址
函数名就是这个地址
② 函数指针就是存函数地址的指针
//int *p 存 int 变量地址
int (*calc)() 存函数地址
//函数指针就是一个变量，它存的是函数的地址，可以随时切换调用不同函数。
//int：表示指向的东西是 int 类型*：表示这是一个指针p：指针变量的名字
