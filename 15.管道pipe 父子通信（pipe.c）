#include <stdio.h>输入输出
#include <unistd.h>pipe、fork、read、write 核心系统调用
#include <string.h>//strlen 计算字符串长度

int main() {
    int fd[2];
    创建管道文件描述符数组
    //fd：file description（文件描述符）
fd[2]：创建一个大小为 2 的数组
作用：管道必须用两个编号表示两头
fd [0] → 读端（只能读，不能写）
fd [1] → 写端（只能写，不能读）
    pipe(fd);
    //pipe()：系统函数，创建一个管道
传入 fd [2]
执行后：
fd [0] = 管道读端编号
fd [1] = 管道写端编号
一句话：
建立一条 “父进程 ↔ 子进程” 的单向通信通道

    if (fork() == 0) {//超级重要：fork () 原理
调用 fork () → 程序分裂成两个进程
父进程：返回值 > 0（子进程 ID）
子进程：返回值 = 0
fork () == 0 → 只有子进程会进入这个大括号
父进程不会进这里，直接跳过去
        close(fd[0]);//子进程只发消息，不读所以关闭读端 fd [0]管道规范：不用的端必须关闭
        char buf[] = "hello from child";
        write(fd[1], buf, strlen(buf));//write：往管道里写数据fd[1]：管道写端把消息写入管道
        close(fd[1]);//写完关闭写端
        return 0;//子进程结束
    }

    close(fd[1]);//父进程只读消息，不写。所以关闭写端 fd [1]
    char buf[100];//父进程接收消息的缓冲区
    int n = read(fd[0], buf, sizeof(buf));//read：从管道读数据fd[0]：管道读端读到的数据放进 buf返回值 n = 读到的字节数
    write(1, buf, n);//write(1, ...)1 = 标准输出（屏幕）。把读到的消息打印到屏幕
    close(fd[0]);//读完关闭读端
    return 0;//程序结束
}
管道（pipe）
父子进程之间通信的 “单向管子”
一头只能读，一头只能写，数据从写端流入，从读端流出。
fork()
创建子进程
调用一次，变成两个进程（父进程 + 子进程），同时往下运行。
文件描述符
系统给每个打开的东西（文件、管道、网络）分配的编号
整个程序运行流程（最清晰版本）
主进程创建管道 fd [0] 读端、fd [1] 写端
调用 fork () → 分裂出父子两个进程
子进程：
关闭读端
写入 "hello from child"
关闭写端
退出
父进程：
关闭写端
从管道读消息
把消息打印到屏幕
关闭读端
结束
你写普通程序时：
只有一个进程
变量之间直接传值就行
但现实中：
一个程序会分裂成多个进程
每个进程内存独立、互不干扰
A 进程的变量，B 进程根本看不见
就像：
两个人住在不同房间
互相听不见、看不见
必须通过电话 / 纸条说话
管道 pipe 就是那个纸条通道。
2. 这段代码实现了什么？
父进程和子进程，本来是完全隔离的。
通过 pipe：
子进程发一句话
父进程能收到
这就实现了：
两个独立进程之间的数据传递
3. 现实中有什么用？（超级重要）
我给你举真实场景，你立刻就懂它为什么必须存在。
场景 1：shell 命令管道
你肯定用过：
plaintext
ls | grep txt
ls 是一个进程
grep 是另一个进程
| 就是 管道
底层就是用 pipe 实现的！
场景 2：大型程序分工协作
主进程：负责网络接收
子进程：负责计算
孙进程：负责写日志
它们之间要互相传数据、传指令，就用管道。
场景 3：父进程监控子进程
子进程崩溃了
父进程通过管道知道
然后重启它
很多服务器、后台程序都这么做。
场景 4：避免一个进程卡死整个程序
一个进程挂了
不影响其他进程
通过管道传递结果
这就是进程隔离 + 通信。
4. 回到你这段代码，它的价值是什么？
它演示了 Linux 最基础、最经典、最必须掌握的能力：
1. 进程可以创建子进程（fork）
2. 进程之间内存隔离，不能直接访问变量
3. 必须用管道（pipe）建立通信通道
4. 一端写、一端读，实现数据传递
5. 最通俗总结
管道 = 两个进程之间的 “秘密传话通道”
没有管道：
多进程就是聋子、瞎子
无法协作
无法传递数据
有了管道：
多进程可以分工合作
可以大规模并发
可以构建复杂系统
最终一句话告诉你它有什么用
** 它让多个独立程序能够互相说话、传递数据，
是 Linux 一切多进程、多任务、复杂服务的基础！*


